{
  "name": "open-master",
  "version": "0.1.0",
  "private": true,
  "description": "Create configurable AI mentor assistants with memory, knowledge, and voice",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "electron:compile": "tsc -p electron/tsconfig.json",
    "memory-engine:build:mac": "bash ./services/memory-engine/build-macos-bundle.sh",
    "mem0-service:install": "npm install --omit=dev --prefix services/mem0-service --legacy-peer-deps",
    "mem0-service:rebuild-electron": "npm rebuild better-sqlite3 --prefix services/mem0-service --runtime=electron --target=40.8.1 --dist-url=https://electronjs.org/headers --build-from-source",
    "electron:dev": "npm run electron:compile && electron .",
    "electron:build": "npm run mem0-service:install && npm run mem0-service:rebuild-electron && npm run electron:compile && npm run build && electron-builder",
    "electron:pack:mac": "npm run memory-engine:build:mac && npm run mem0-service:install && npm run mem0-service:rebuild-electron && npm run electron:compile && npm run build && electron-builder --mac --arm64",
    "memory-engine:dev": "docker compose up memory-engine",
    "docker:dev": "docker compose up",
    "docker:build": "docker compose build",
    "docker:down": "docker compose down"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^2.0.0",
    "@ai-sdk/openai": "^2.0.0",
    "@ai-sdk/openai-compatible": "^2.0.35",
    "@ai-sdk/react": "^3.0.0",
    "@anthropic-ai/sdk": "^0.78.0",
    "@azure/identity": "^4.13.0",
    "@azure/search-documents": "^12.2.0",
    "@google/genai": "^1.45.0",
    "@lancedb/lancedb": "^0.26.2",
    "@langchain/core": "^1.1.32",
    "@mistralai/mistralai": "^1.15.1",
    "@openrouter/ai-sdk-provider": "^2.3.0",
    "@qdrant/js-client-rest": "^1.17.0",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.0.0",
    "@radix-ui/react-scroll-area": "^1.0.0",
    "@radix-ui/react-slot": "^1.0.0",
    "@supabase/supabase-js": "^2.99.1",
    "ai": "^6.0.0",
    "apache-arrow": "^21.1.0",
    "better-sqlite3": "^12.6.0",
    "class-variance-authority": "^0.7.0",
    "cloudflare": "^5.2.0",
    "clsx": "^2.1.0",
    "dotenv": "^16.0.0",
    "groq-sdk": "^1.1.1",
    "lucide-react": "^0.500.0",
    "mem0ai": "^2.3.0",
    "motion": "^12.0.0",
    "neo4j-driver": "^6.0.1",
    "next": "^16.0.0",
    "next-themes": "^0.4.0",
    "ollama": "^0.6.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "redis": "^5.11.0",
    "tailwind-merge": "^3.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "concurrently": "^9.0.0",
    "electron": "^40.0.0",
    "electron-builder": "^25.0.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "wait-on": "^8.0.0"
  }
}
