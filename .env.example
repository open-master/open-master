# ============================================
# open-master 开发环境配置
# 复制此文件为 .env 后填入你的密钥
# ============================================

# ---- LLM Providers ----
ANTHROPIC_API_KEY=sk-ant-xxx
OPENAI_API_KEY=sk-xxx

# ---- Memory (Mem0) ----
# 留空则使用开源本地模式
MEM0_API_KEY=

# ---- 语音 (Phase 3) ----
ELEVENLABS_API_KEY=

# ---- 视频 (Phase 4) ----
DID_API_KEY=

# ---- 服务端口 ----
WEB_PORT=3100
MEMORY_ENGINE_PORT=8000

# ---- 数据存储路径 ----
DATA_DIR=./data
KUZU_DB_PATH=./data/kuzu
LANCEDB_PATH=./data/lancedb
SQLITE_PATH=./data/sqlite/open-master.db

# ---- 开发选项 ----
NODE_ENV=development
LOG_LEVEL=debug
